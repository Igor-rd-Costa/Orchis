<Window x:Class="OrchisEditor.View.Editor.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OrchisEditor.View.Editor"
        xmlns:UserControls="clr-namespace:OrchisEditor.View.Editor.UserControls"
        xmlns:WindowComponents="clr-namespace:OrchisEditor.View.Editor.UserControls.WindowComponents"
        mc:Ignorable="d" Style="{StaticResource OrchisWindowBordered}" MouseMove="Window_MouseMove" 
        Title="" Height="900" Width="1600" MouseDown="Window_MouseDown" KeyDown="Window_KeyDown" KeyUp="Window_KeyUp"
        MouseLeftButtonDown="Window_MouseLeftButtonDown" MouseLeftButtonUp="Window_MouseLeftButtonUp">
    <Grid x:Name="WindowGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="80*"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="25*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="30"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="17.1*"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="30"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="7" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="90"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>
            <Image Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0" Grid.RowSpan="2" 
                       Source="/Assets/Textures/default_Base_Color.png"></Image>
            <Border BorderBrush="Red" BorderThickness="1" Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0" Grid.RowSpan="2"></Border>
            <TextBlock Name="Header" Margin="5 0 0 0" Grid.Column="2" FontFamily="Arial" 
                           HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="13" Foreground="#DDDDDD">New Project - Orchis Engine</TextBlock>
            <WindowComponents:SysMenu x:Name="SystemMenu" Grid.Column="3" Width="90" HorizontalAlignment="Right"/>
            <UserControls:MenuBar Margin="5 0 0 0" Grid.Column="2" Grid.Row="1" Grid.ColumnSpan="1" Height="30"/>
        </Grid>
        <UserControls:Outliner x:Name="ProjectOutliner" Grid.Column="1" Grid.Row="3" Grid.RowSpan="3"/>
        <GridSplitter Grid.Row="3" Grid.Column="2" Grid.RowSpan="3" HorizontalAlignment="Stretch" Background="Transparent"/>
        <UserControls:SceneViewer x:Name="SceneRenderer" Grid.Column ="3" Grid.Row="3"/>
        <GridSplitter Grid.Row="3" Grid.Column="4" Grid.RowSpan="3" HorizontalAlignment="Stretch" Background="Transparent"/>
        <UserControls:PropertyPanel x:Name="PropertiesPanel" Grid.Column="5" Grid.Row="3" Grid.RowSpan="3"/>
        <GridSplitter Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="3" HorizontalAlignment="Stretch" Background="Transparent"/>
        <UserControls:ToolsPanel x:Name="ToolsPanel" Grid.Column="3" Grid.Row="5" Grid.ColumnSpan="1"/>
    </Grid>
</Window>
