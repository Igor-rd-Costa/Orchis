<UserControl x:Class="OrchisEditor.View.Editor.UserControls.ToolsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OrchisEditor.View.Editor.UserControls"
             xmlns:ToolsPanelComponents="clr-namespace:OrchisEditor.View.Editor.UserControls.ToolsPanelComponents"
             mc:Ignorable="d" 
             d:DesignHeight="225" d:DesignWidth="800">
    <Grid>
        <TabControl Background="Transparent" BorderBrush="LightGray" BorderThickness="0.2">
            <TabItem Background="Transparent">
                <TabItem.Header>Assets</TabItem.Header>
                <TabItem.Content>
                    <ToolsPanelComponents:AssetManager></ToolsPanelComponents:AssetManager>
                </TabItem.Content>
            </TabItem>
            <TabItem Background="Transparent">
                <TabItem.Header>Output</TabItem.Header>
                <TabItem.Content>
                    <ToolsPanelComponents:Logger></ToolsPanelComponents:Logger>
                </TabItem.Content>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
