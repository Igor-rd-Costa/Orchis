<UserControl x:Class="OrchisEditor.View.Editor.UserControls.OutlinerComponents.ProjectHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OrchisEditor.View.Editor.UserControls.OutlinerComponents"
             mc:Ignorable="d" 
             d:DesignHeight="20" d:DesignWidth="450">
    <Grid x:Name="Wrapper" Margin="1 0 1 0"
          MouseLeftButtonDown="Wrapper_MouseLeftButtonDown" MouseEnter="Wrapper_MouseEnter" MouseLeave="Wrapper_MouseLeave">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Image Width="20" Height="20" HorizontalAlignment="Right" Grid.Column="0"/>
        <TextBlock Text="{Binding ProjectName}" Grid.Column="1" TextAlignment="Left"
                   Background="Transparent" Foreground="White" Padding="5,0,0,0"/>
    </Grid>
</UserControl>
