<Window x:Class="OrchisEditor.View.Editor.UserControls.ToolsPanelComponents.AssetManagerComponents.AssetImportForm.AssetImportForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OrchisEditor.View.Editor.UserControls.ToolsPanelComponents.AssetManagerComponents.AssetImportForm"
        xmlns:WindowComponents="clr-namespace:OrchisEditor.View.Editor.UserControls.WindowComponents"
        mc:Ignorable="d" Style="{StaticResource OrchisWindow}" ResizeMode="NoResize"
        Title="AssetImportForm" Width="500" Height="600" MouseDown="Window_MouseDown">
    <Grid Name="WindowGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <WindowComponents:SysMenu x:Name="SystemMenu" HorizontalAlignment="Right"/>
    </Grid>
</Window>
