<UserControl x:Class="OrchisEditor.View.Editor.UserControls.MenuBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OrchisEditor.View.Editor.UserControls"
             xmlns:WindowComponents="clr-namespace:OrchisEditor.View.Editor.UserControls.WindowComponents"
             mc:Ignorable="d" 
             d:DesignHeight="30" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Menu Grid.Column="0" VerticalAlignment="Center" FontFamily="Arial" FontSize="14">
            <MenuItem>
                <MenuItem.Header>
                    <TextBlock Text="File" VerticalAlignment="Center" TextAlignment="Center"/>
                </MenuItem.Header>
                <MenuItem Header="Exit"/>
            </MenuItem>
        </Menu>
    </Grid>
</UserControl>
