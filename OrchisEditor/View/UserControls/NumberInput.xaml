<UserControl x:Class="OrchisEditor.View.UserControls.NumberInput"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OrchisEditor.View.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <TextBox Name="Input" Foreground="LightGray" Background="Transparent" BorderBrush="#404040" Text="{Binding Value}"
             PreviewKeyDown="OnKeyDown" PreviewTextInput="OnTextInputPreview"></TextBox>
</UserControl>
